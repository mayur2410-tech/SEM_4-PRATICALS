pipeline {
    agent any

    environment {
        NODE_ENV = 'test'
        PORT = '3000'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Run Lint (Optional)') {
            steps {
                sh 'npm run lint || true'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'npm test || true'
            }
        }

        stage('Start App (Smoke Test)') {
            steps {
                script {
                    sh '''
                    node app.js &
                    sleep 5
                    curl -f http://localhost:3000 || exit 1
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Build Passed ✅'
        }
        failure {
            echo 'Build Failed ❌'
        }
        always {
            sh 'pkill -f node || true'
        }
    }
}